class Backtester:
    """回测引擎"""

    def __init__(self, initial_capital=1000000):
        self.initial_capital = initial_capital
        self.trades = []
        self.positions = {}

    def run_backtest(self, strategy, data):
        """运行回测"""
        for date in data.index:
            # 获取当日数据
            daily_data = data.loc[date]

            # 选股
            selected_stocks = strategy.select_stocks(daily_data)

            # 交易
            self.execute_trades(selected_stocks, date)

        return self.calculate_performance()

