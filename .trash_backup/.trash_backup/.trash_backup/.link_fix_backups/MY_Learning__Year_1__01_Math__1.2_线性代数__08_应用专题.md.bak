## 5. 综合案例

### 5.1 股票组合优化

```python
import numpy as np
from scipy.optimize import minimize

def portfolio_optimization(returns, target_return):
    """均值方差组合优化"""
    n = returns.shape[1]
    mu = returns.mean(axis=0)
    cov = np.cov(returns.T)
    
    # 目标函数：最小化方差
    def objective(w):
        return w.T @ cov @ w
    
    # 约束条件
    constraints = [
        {'type': 'eq', 'fun': lambda w: np.sum(w) - 1},  # 权重和为1
        {'type': 'eq', 'fun': lambda w: w.T @ mu - target_return}  # 目标收益
    ]
    bounds = [(0, 1) for _ in range(n)]  # 不允许做空
    
    # 初始值
    w0 = np.ones(n) / n
    
    # 优化
    result = minimize(objective, w0, method='SLSQP', 
                      bounds=bounds, constraints=constraints)
    
    return result.x

# 测试
np.random.seed(42)
returns = np.random.randn(252, 10) * 0.02 + 0.0005
optimal_weights = portfolio_optimization(returns, target_return=0.001)

print("最优权重:")
for i, w in enumerate(optimal_weights):
    print(f"资产{i+1}: {w:.2%}")
```

### 5.2 神经信号解码

```python
import numpy as np
from sklearn.linear_model import Ridge
from sklearn.model_selection import cross_val_score

def neural_decoding(neural_activity, behavior, n_components=20):
    """神经信号解码（使用PCA预处理）"""
    # PCA 降维
    from sklearn.decomposition import PCA
    pca = PCA(n_components=n_components)
    neural_pca = pca.fit_transform(neural_activity)
    
    # Ridge 回归解码
    decoder = Ridge(alpha=1.0)
    scores = cross_val_score(decoder, neural_pca, behavior, cv=5, 
                             scoring='neg_mean_squared_error')
    
    return -scores.mean(), pca.explained_variance_ratio_

# 模拟数据
np.random.seed(42)
n_neurons = 100
n_timepoints = 500

neural_activity = np.random.randn(n_timepoints, n_neurons)
behavior = neural_activity[:, :5].sum(axis=1) + np.random.randn(n_timepoints) * 0.1

mse, var_ratio = neural_decoding(neural_activity, behavior)
print(f"解码 MSE: {mse:.4f}")
print(f"前20个主成分解释方差: {sum(var_ratio):.2%}")
```

