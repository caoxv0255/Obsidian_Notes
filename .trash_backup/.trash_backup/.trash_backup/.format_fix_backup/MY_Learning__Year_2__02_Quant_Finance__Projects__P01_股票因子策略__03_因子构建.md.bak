### 完整实现

```python
"""
因子构建模块
"""
import pandas as pd
import numpy as np
from scipy import stats

class FactorBuilder:
    """因子构建器"""

    def __init__(self, data_processor):
        """
        初始化因子构建器

        参数:
            data_processor: 数据处理器实例
        """
        self.dp = data_processor

    def build_momentum_factor(self, df, window=20):
        """
        动量因子

        逻辑：过去N个月的收益率

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 动量因子值
        """
        # 计算N日收益率
        momentum = df['close'].pct_change(window)

        return momentum

    def build_reversal_factor(self, df, window=5):
        """
        反转因子

        逻辑：短期反向交易

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 反转因子值
        """
        # 计算N日收益率（取负值）
        reversal = -df['close'].pct_change(window)

        return reversal

    def build_volatility_factor(self, df, window=20):
        """
        波动率因子

        逻辑：价格波动程度

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 波动率因子值（取负值，波动率越低越好）
        """
        # 计算N日收益率
        returns = df['close'].pct_change()

        # 计算滚动标准差
        volatility = returns.rolling(window).std()

        # 取负值（波动率越低越好）
        return -volatility

    def build_liquidity_factor(self, df, window=20):
        """
        流动性因子

        逻辑：换手率越高流动性越好

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 流动性因子值
        """
        # 使用成交额作为流动性指标
        liquidity = df['amount'].rolling(window).mean()

        # 标准化
        liquidity = liquidity / liquidity.max()

        return liquidity

    def build_technical_factors(self, df):
        """
        构建技术因子

        参数:
            df: 日线数据

        返回:
            DataFrame: 技术因子数据
        """
        factors = pd.DataFrame(index=df.index)

        # 动量因子
        factors['momentum'] = self.build_momentum_factor(df, window=20)

        # 反转因子
        factors['reversal'] = self.build_reversal_factor(df, window=5)

        # 波动率因子
        factors['volatility'] = self.build_volatility_factor(df, window=20)

        # 流动性因子
        factors['liquidity'] = self.build_liquidity_factor(df, window=20)

        return factors

    def build_pe_ratio_factor(self, financial_df):
        """
        PE比率因子

        逻辑：估值越低越安全

        参数:
            financial_df: 财务数据

        返回:
            Series: PE比率因子值（取负值）
        """
        # 使用TTM PE
        pe_ratio = -financial_df['pe_ttm']

        return pe_ratio

    def build_pb_ratio_factor(self, financial_df):
        """
        PB比率因子

        逻辑：估值越低越安全

        参数:
            financial_df: 财务数据

        返回:
            Series: PB比率因子值（取负值）
        """
        pb_ratio = -financial_df['pb']

        return pb_ratio

    def build_roe_factor(self, financial_df):
        """
        ROE因子

        逻辑：盈利能力越强越好

        参数:
            financial_df: 财务数据

        返回:
            Series: ROE因子值
        """
        # ROE = 净利润 / 股东权益
        # 这里简化处理，使用市值增长率代替
        roe = financial_df['circ_mv'].pct_change()

        return roe

    def build_revenue_growth_factor(self, financial_df):
        """
        营收增长率因子

        逻辑：成长性越高越好

        参数:
            financial_df: 财务数据

        返回:
            Series: 营收增长率因子值
        """
        # 使用市值增长率代替营收增长率
        revenue_growth = financial_df['circ_mv'].pct_change()

        return revenue_growth

    def build_fundamental_factors(self, financial_df):
        """
        构建基本面因子

        参数:
            financial_df: 财务数据

        返回:
            DataFrame: 基本面因子数据
        """
        factors = pd.DataFrame(index=financial_df.index)

        # PE比率因子
        factors['pe_ratio'] = self.build_pe_ratio_factor(financial_df)

        # PB比率因子
        factors['pb_ratio'] = self.build_pb_ratio_factor(financial_df)

        # ROE因子
        factors['roe'] = self.build_roe_factor(financial_df)

        # 营收增长率因子
        factors['revenue_growth'] = self.build_revenue_growth_factor(financial_df)

        return factors

    def build_turnover_factor(self, df, window=20):
        """
        换手率因子

        逻辑：换手率过高可能见顶

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 换手率因子值（取负值）
        """
        # 换手率 = 成交量 / 流通股本
        # 简化处理：使用成交量的滚动均值
        turnover = df['vol'].rolling(window).mean()

        # 取负值（换手率越低越好）
        return -turnover

    def build_money_flow_factor(self, df, window=5):
        """
        资金流向因子

        逻辑：资金流入推动上涨

        参数:
            df: 日线数据
            window: 回看窗口（交易日）

        返回:
            Series: 资金流向因子值
        """
        # 使用涨跌幅作为资金流向的代理
        # 涨跌幅越大，资金流入越多
        money_flow = df['pct_chg'].rolling(window).sum()

        return money_flow

    def build_sentiment_factors(self, df):
        """
        构建情绪因子

        参数:
            df: 日线数据

        返回:
            DataFrame: 情绪因子数据
        """
        factors = pd.DataFrame(index=df.index)

        # 换手率因子
        factors['turnover_rate'] = self.build_turnover_factor(df, window=20)

        # 资金流向因子
        factors['money_flow'] = self.build_money_flow_factor(df, window=5)

        return factors

    def build_all_factors(self, daily_df, financial_df):
        """
        构建所有因子

        参数:
            daily_df: 日线数据
            financial_df: 财务数据

        返回:
            DataFrame: 所有因子数据
        """
        # 构建技术因子
        tech_factors = self.build_technical_factors(daily_df)

        # 构建基本面因子
        fund_factors = self.build_fundamental_factors(financial_df)

        # 构建情绪因子
        sent_factors = self.build_sentiment_factors(daily_df)

        # 合并所有因子
        all_factors = pd.concat([tech_factors, fund_factors, sent_factors], axis=1)

        return all_factors

    def standardize_factors(self, df, method='zscore'):
        """
        因子标准化

        参数:
            df: 因子数据
            method: 标准化方法 ('zscore', 'rank', 'minmax')

        返回:
            DataFrame: 标准化后的因子数据
        """
        df_standardized = df.copy()

        for col in df.columns:
            if method == 'zscore':
                # Z-score标准化
                mean = df[col].mean()
                std = df[col].std()
                if std > 0:
                    df_standardized[col] = (df[col] - mean) / std

            elif method == 'rank':
                # 秩标准化
                df_standardized[col] = df[col].rank(pct=True)

            elif method == 'minmax':
                # Min-Max标准化
                min_val = df[col].min()
                max_val = df[col].max()
                if max_val > min_val:
                    df_standardized[col] = (df[col] - min_val) / (max_val - min_val)

        return df_standardized

    def neutralize_factors(self, factor_df, neutralize_cols=None):
        """
        因子中性化（去行业、去市值）

        参数:
            factor_df: 因子数据
            neutralize_cols: 需要中性化的列

        返回:
            DataFrame: 中性化后的因子数据
        """
        if neutralize_cols is None:
            neutralize_cols = factor_df.columns

        df_neutralized = factor_df.copy()

        for col in neutralize_cols:
            # 对每个因子进行中性化
            y = factor_df[col].dropna()

            if len(y) == 0:
                continue

            # 使用均值去中心化（简化处理）
            mean = y.mean()
            df_neutralized[col] = factor_df[col] - mean

        return df_neutralized

    def save_factors(self, factor_df, ts_code):
        """
        保存因子数据到数据库

        参数:
            factor_df: 因子数据
            ts_code: 股票代码
        """
        # 添加股票代码列
        factor_df['ts_code'] = ts_code

        # 重置索引
        factor_df = factor_df.reset_index()

        # 保存到数据库
        cursor = self.dp.conn.cursor()

        # 删除旧数据
        cursor.execute(f"DELETE FROM factor_data WHERE ts_code = '{ts_code}'")

        # 插入新数据
        for _, row in factor_df.iterrows():
            cursor.execute('''
                INSERT INTO factor_data VALUES (
                    ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?
                )
            ''', (
                row['ts_code'], row['trade_date'],
                row.get('momentum', np.nan), row.get('reversal', np.nan),
                row.get('volatility', np.nan), row.get('liquidity', np.nan),
                row.get('pe_ratio', np.nan), row.get('pb_ratio', np.nan),
                row.get('roe', np.nan), row.get('revenue_growth', np.nan),
                row.get('turnover_rate', np.nan)
            ))

        self.dp.conn.commit()
        print(f"因子数据已保存: {ts_code}")

# 使用示例
def test_factor_builder():
    """测试因子构建器"""
    print("=" * 50)
    print("因子构建器测试")
    print("=" * 50)

    # 导入数据处理器
    from data_processor import DataProcessor

    # 创建数据处理器和因子构建器
    dp = DataProcessor()
    fb = FactorBuilder(dp)

    # 获取股票列表
    cursor = dp.conn.cursor()
    cursor.execute("SELECT ts_code FROM stock_list LIMIT 3")
    stock_list = [row[0] for row in cursor.fetchall()]

    # 测试一只股票
    ts_code = stock_list[0]
    print(f"\n测试股票: {ts_code}")

    # 获取数据
    daily_df = dp.get_data('daily_data', ts_code=ts_code)
    financial_df = dp.get_data('financial_data', ts_code=ts_code)

    print(f"日线数据: {len(daily_df)} 行")
    print(f"财务数据: {len(financial_df)} 行")

    # 构建技术因子
    print("\n1. 构建技术因子")
    tech_factors = fb.build_technical_factors(daily_df)
    print(tech_factors.describe())

    # 构建基本面因子
    print("\n2. 构建基本面因子")
    fund_factors = fb.build_fundamental_factors(financial_df)
    print(fund_factors.describe())

    # 构建情绪因子
    print("\n3. 构建情绪因子")
    sent_factors = fb.build_sentiment_factors(daily_df)
    print(sent_factors.describe())

    # 构建所有因子
    print("\n4. 构建所有因子")
    all_factors = fb.build_all_factors(daily_df, financial_df)
    print(f"因子数量: {len(all_factors.columns)}")
    print(all_factors.describe())

    # 因子标准化
    print("\n5. 因子标准化（Z-score）")
    standardized_factors = fb.standardize_factors(all_factors, method='zscore')
    print(standardized_factors.describe())

    # 因子中性化
    print("\n6. 因子中性化")
    neutralized_factors = fb.neutralize_factors(standardized_factors)
    print(neutralized_factors.describe())

    # 保存因子
    print("\n7. 保存因子数据")
    fb.save_factors(neutralized_factors, ts_code)

    # 关闭连接
    dp.close()

if __name__ == '__main__':
    test_factor_builder()
```

---

## 因子质量检查

### 因子有效性指标

**IC（信息系数）**：
$$IC = \rho(Factor, Return)$$

**IR（信息比率）**：
$$IR = \frac{mean(IC)}{std(IC)}$$

**t统计量**：
$$t = \frac{mean(IC)}{std(IC) / \sqrt{n}}$$

### 因子稳定性检查
- **时序稳定性**：IC随时间的变化
- **横截面稳定性**：因子在股票间的分布
- **换手率**：因子组合的股票更换频率

---

## 因子优化

### 因子组合方法
1. **等权组合**：所有因子权重相同
2. **IC加权**：按IC值加权
3. **IR加权**：按IR值加权
4. **机器学习优化**：使用回归或树模型

### 因子去重
1. **相关性分析**：计算因子间相关系数
2. **正交化**：使用PCA或回归去重
3. **聚类分析**：将相似因子分组

