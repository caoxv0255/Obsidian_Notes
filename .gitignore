# 忽略 Obsidian 的插件、主题和缓存
.obsidian/plugins/
.obsidian/themes/
.obsidian/cache/

# 忽略工作区布局（防止每次打开软件都产生变更）
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# 忽略系统文件
.DS_Store
Thumbs.db

# 忽略 Python 缓存
__pycache__/
*.pyc

# 忽略所有附件文件
*.pdf
*.png
*.jpg
*.jpeg
*.mp4
*.mov
*.avi
*.zip
*.tar.gz
*.docx
*.xlsx
*.pptx
*.epub
*.mobi
